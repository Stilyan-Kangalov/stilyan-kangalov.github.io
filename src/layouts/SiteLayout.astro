---
import BaseLayout from "@/layouts/BaseLayout.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  metadata?: {
    title?: string;
    description?: string;
    ogImage?: string;
    canonical?: string;
    ignoreTitleTemplate?: boolean;
  };
}

const { title, description, ogImage, canonical, metadata } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  canonical={canonical}
  metadata={metadata}
>
  <slot />
</BaseLayout>
