---
import SiteLayout from "@/layouts/SiteLayout.astro";
import type { GetStaticPathsOptions } from "astro";
import BlogPostListSection from "@/components/sections/blog/BlogPostListSection.astro";
import { getPublishedSortedPosts } from "@/utils/blog";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const sortedPosts = await getPublishedSortedPosts();
  return paginate(sortedPosts, { pageSize: 6 });
}

const { page } = Astro.props;

const metadata = {
  title: "Posts",
  description: "Latest news and updates from our team.",
};
---

<SiteLayout metadata={metadata}>
  <BlogPostListSection {page} />
</SiteLayout>
