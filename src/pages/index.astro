---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { siteConfig } from "@/config/site";
import PostItem from "@/components/PostItem.astro";
import { getPublishedSortedPosts } from "@/utils/blog";

const allPosts = await getPublishedSortedPosts();
const markedFeatured = allPosts.filter((post) => post.data.featured);
const featuredPosts =
  markedFeatured.length > 0 ? markedFeatured.slice(0, 2) : allPosts.slice(0, 2);
const latestPosts = allPosts
  .filter(
    (post) =>
      !featuredPosts.some((featuredPost) => featuredPost.id === post.id),
  )
  .slice(0, 6);

const metadata = {
  title: `${siteConfig.name} — Web Development Insights & Tutorials`,
  description:
    "Short reads on web development, practical engineering, and software craftsmanship by Stilyan.",
  ignoreTitleTemplate: true,
};
---

<SiteLayout {metadata}>
  <section class="relative px-4 py-12 sm:px-6 lg:px-8 md:py-16">
    <div class="mx-auto max-w-5xl">
      <div class="reveal rounded-3xl border border-border bg-card p-8 md:p-10">
        <p class="text-sm font-semibold tracking-wide text-primary uppercase">
          Hello, I am Stilyan
        </p>
        <h1
          class="font-heading mt-3 text-4xl font-bold tracking-tight text-foreground md:text-6xl"
        >
          Web Developer writing about practical engineering.
        </h1>
        <p class="mt-5 max-w-3xl text-lg text-muted-foreground">
          This is my digital notebook where I share concise, useful posts about
          modern web development, architecture decisions, and lessons from real
          projects.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="/posts"
            class="inline-flex items-center rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-background transition-colors hover:bg-primary/90"
          >
            Browse posts
          </a>
          <a
            href="/about"
            class="inline-flex items-center rounded-xl border border-border px-5 py-2.5 text-sm font-semibold text-foreground transition-colors hover:bg-muted"
          >
            About Me
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="relative px-4 py-6 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div class="mb-8 flex items-center gap-3">
        <h2 class="text-sm font-bold tracking-widest text-primary uppercase">
          Featured Articles
        </h2>
        <div class="h-px flex-1 bg-border/20"></div>
      </div>
      <div class="grid gap-8 md:grid-cols-2">
        {featuredPosts.map((post) => <PostItem post={post} />)}
      </div>
    </div>
  </section>

  <section class="relative px-4 py-10 sm:px-6 lg:px-8 md:py-12">
    <div class="mx-auto max-w-5xl">
      <div class="mb-8 flex items-center gap-3">
        <h2 class="text-sm font-bold tracking-widest uppercase">
          Latest Posts
        </h2>
        <div class="h-px flex-1 bg-border/20"></div>
      </div>
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {latestPosts.map((post) => <PostItem post={post} />)}
      </div>
      <div class="mt-10 text-center">
        <a
          href="/posts"
          class="inline-flex items-center rounded-xl border border-primary/30 bg-primary/10 px-6 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary/20"
        >
          View all posts
        </a>
      </div>
    </div>
  </section>
</SiteLayout>
